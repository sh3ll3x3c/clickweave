    <mxCell id="e_comp_cmd" value="invoke commands" style="html=1;edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=12;fontColor=#b85450;" edge="1" source="comp_app" target="cmd_executor" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Events to Store -->
    <mxCell id="e_evt_store" value="events update store via useStore.getState()" style="html=1;edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#d6b656;exitX=0;exitY=0;exitDx=0;exitDy=0;fontSize=11;fontColor=#996600;" edge="1" source="evt_exec" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="400" y="135" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="1950" y="200"/>
          <mxPoint x="1950" y="135"/>
          <mxPoint x="400" y="135"/>
        </Array>
      </mxGeometry>
    </mxCell>

  </root>
</mxGraphModel>