{
  "id": "synthetic_electron_pre_cdp",
  "description": "Synthetic Electron app routing check. The agent should not use visual or coordinate fallback before CDP is connected.",
  "goal": "Launch SyntheticChat and open the message composer using the structured app surface.",
  "max_steps": 6,
  "tools": [
    {
      "name": "launch_app",
      "description": "Launch a synthetic app by name.",
      "parameters": {
        "type": "object",
        "required": ["app_name"],
        "properties": {
          "app_name": { "type": "string" },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "probe_app",
      "description": "Classify a synthetic app by name.",
      "parameters": {
        "type": "object",
        "properties": {
          "app_name": { "type": "string" }
        }
      }
    },
    {
      "name": "quit_app",
      "description": "Quit a synthetic app before relaunching with a debug port.",
      "parameters": {
        "type": "object",
        "required": ["app_name"],
        "properties": {
          "app_name": { "type": "string" }
        }
      }
    },
    {
      "name": "list_apps",
      "description": "List synthetic running apps.",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "cdp_connect",
      "description": "Connect to a synthetic debug port.",
      "parameters": {
        "type": "object",
        "required": ["port"],
        "properties": {
          "port": { "type": "integer" }
        }
      }
    },
    {
      "name": "cdp_list_pages",
      "description": "List synthetic CDP pages after connection.",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "cdp_find_elements",
      "description": "Find elements on the connected synthetic page.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": { "type": "string" }
        }
      }
    },
    {
      "name": "cdp_click",
      "description": "Click a synthetic CDP element by uid.",
      "parameters": {
        "type": "object",
        "required": ["uid"],
        "properties": {
          "uid": { "type": "string" }
        }
      }
    },
    {
      "name": "take_ax_snapshot",
      "description": "Native AX snapshot. This scenario treats it as the wrong family.",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "take_screenshot",
      "description": "Screenshot observation. This scenario treats it as visual fallback.",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "find_text",
      "description": "OCR text search. This scenario treats it as visual fallback.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": { "type": "string" }
        }
      }
    },
    {
      "name": "click",
      "description": "Coordinate click. This scenario treats it as forbidden fallback.",
      "parameters": {
        "type": "object",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        }
      }
    }
  ],
  "tool_behaviors": [
    {
      "tool": "launch_app",
      "required_args": ["app_name"],
      "response": { "app_name": "SyntheticChat", "kind": "ElectronApp", "pid": 1001 }
    },
    {
      "tool": "probe_app",
      "response": { "app_name": "SyntheticChat", "kind": "ElectronApp", "pid": 1001 }
    },
    {
      "tool": "quit_app",
      "required_args": ["app_name"],
      "response": "SyntheticChat quit"
    },
    {
      "tool": "list_apps",
      "response": []
    },
    {
      "tool": "cdp_connect",
      "required_args": ["port"],
      "sets_state": { "cdp_connected": true },
      "response": "Connected to SyntheticChat. Selected page: app://synthetic-chat/main"
    },
    {
      "tool": "cdp_list_pages",
      "requires_state": { "cdp_connected": true },
      "response": "Pages (1 total):\n  [0]* app://synthetic-chat/main\n"
    },
    {
      "tool": "cdp_find_elements",
      "requires_state": { "cdp_connected": true },
      "response": {
        "page_url": "app://synthetic-chat/main",
        "source": "cdp",
        "matches": [
          {
            "uid": "d1",
            "role": "textbox",
            "label": "Message",
            "tag": "textarea",
            "disabled": false
          }
        ]
      }
    },
    {
      "tool": "cdp_click",
      "required_args": ["uid"],
      "requires_state": { "cdp_connected": true },
      "response": "Synthetic composer focused"
    },
    {
      "tool": "take_ax_snapshot",
      "response": "AX tree contains only synthetic window chrome"
    },
    {
      "tool": "take_screenshot",
      "response": "Synthetic screenshot omitted"
    },
    {
      "tool": "find_text",
      "response": "No OCR match in synthetic page"
    },
    {
      "tool": "click",
      "response": "Coordinate click ignored by synthetic page"
    }
  ],
  "scoring": {
    "required_tools": ["launch_app", "cdp_connect", "cdp_find_elements", "cdp_click"],
    "forbidden_tools": ["take_ax_snapshot", "take_screenshot", "find_text", "click"],
    "required_agent_tools": ["launch_app", "cdp_click", "agent_done"],
    "forbidden_agent_tools": ["cdp_connect", "take_ax_snapshot", "take_screenshot", "find_text", "click"],
    "max_agent_tool_calls": 4,
    "completion_required": true
  }
}
